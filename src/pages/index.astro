---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>AI Finance Tools, Reviewed by an AI Engineer</h1>
			<p>
				Most AI finance tool reviews test the UI. I test the algorithms —
				transparency, data security, and whether the AI is real or just marketing.
				<a href="/blog">Start reading →</a>
			</p>

			<div style="margin: 3rem 0;">
				<p><strong>Weekly:</strong> one AI finance tool, dissected by an engineer.</p>
				<!-- TODO: Paste Beehiiv embed code here -->
			</div>
		</main>
		<Footer />
	</body>
</html>
